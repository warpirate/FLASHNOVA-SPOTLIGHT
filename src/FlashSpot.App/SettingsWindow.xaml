<Window x:Class="FlashSpot.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlashSpot Settings"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        MinWidth="920"
        MinHeight="720"
        Width="1040"
        Height="860"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F2F6FA" />
        <SolidColorBrush x:Key="TextSecondary" Color="#BCC7D3" />
        <SolidColorBrush x:Key="TextMuted" Color="#8D99AA" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#596476" />

        <LinearGradientBrush x:Key="BackdropGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2A2F37" Offset="0" />
            <GradientStop Color="#1D2229" Offset="0.5" />
            <GradientStop Color="#151A20" Offset="1" />
        </LinearGradientBrush>

        <DrawingBrush x:Key="StripeOverlay"
                      TileMode="Tile"
                      Viewport="0,0,28,28"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,28,28"
                      ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#11FFFFFF">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,10,28" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#08000000">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="10,0,18,28" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#4A5667" />
            <Setter Property="BorderBrush" Value="#79879C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5A677A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3F4A5A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="86" Height="44">
                            <Border x:Name="Track"
                                    CornerRadius="22"
                                    Background="#6B7382"
                                    BorderBrush="#8E96A4"
                                    BorderThickness="1" />
                            <Ellipse x:Name="Thumb"
                                     Width="34"
                                     Height="34"
                                     Margin="5,5,0,5"
                                     HorizontalAlignment="Left"
                                     Fill="#D8DDE5" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#627C9E" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#A7BCD9" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,5,5,5" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#F3F7FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="20"
            CornerRadius="24"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1.2">
        <Grid>
            <Border CornerRadius="24"
                    Background="{StaticResource BackdropGradient}" />
            <Border CornerRadius="24"
                    Background="{StaticResource StripeOverlay}"
                    Opacity="0.35" />

            <Grid Margin="34,28,34,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="FlashSpot Settings" />

                    <Button Grid.Column="1"
                            Width="44"
                            Height="44"
                            FontFamily="Bahnschrift SemiBold"
                            FontSize="20"
                            Background="#4B5666"
                            Foreground="{StaticResource TextPrimary}"
                            BorderBrush="#74839A"
                            BorderThickness="1"
                            Cursor="Hand"
                            Content="X"
                            Click="CloseButton_Click" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,22,0,6"
                           Style="{StaticResource SubHeaderStyle}"
                           Text="Index status" />

                <Border Grid.Row="2"
                        CornerRadius="30"
                        BorderThickness="1"
                        BorderBrush="#5D697B"
                        Background="#374251"
                        Padding="22,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="IndexStatusValueText"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="22"
                                   VerticalAlignment="Center"
                                   Text="Ready | Indexed 0 items" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Margin="14,0,0,0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Content="Refresh"
                                    Click="RefreshButton_Click" />
                            <Button x:Name="ReindexButton"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#3A6B9F"
                                    BorderBrush="#5A99D6"
                                    Content="Reindex"
                                    Click="ReindexButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="LastUpdatedText"
                           Grid.Row="3"
                           Margin="0,7,4,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextMuted}"
                           FontFamily="Bahnschrift SemiBold"
                           FontSize="16"
                           Text="Last updated: Just now" />

                <TextBlock Grid.Row="4"
                           Margin="0,24,0,6"
                           Style="{StaticResource SubHeaderStyle}"
                           Text="Queue" />

                <Border Grid.Row="5"
                        CornerRadius="30"
                        BorderThickness="1"
                        BorderBrush="#5D697B"
                        Background="#374251"
                        Padding="22,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="QueueStatusValueText"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="22"
                                   VerticalAlignment="Center"
                                   Text="Pending 0 | Failed 0" />

                        <Button Grid.Column="1"
                                Margin="14,0,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="View Queue"
                                Click="ViewQueueButton_Click" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="6"
                           Margin="0,28,0,8"
                           Style="{StaticResource SubHeaderStyle}"
                           Text="Shortcuts" />

                <Grid Grid.Row="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            CornerRadius="22"
                            BorderThickness="1"
                            BorderBrush="#7A8698"
                            Padding="18,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HotkeyShortcutKeyText"
                                       Text="Alt+Space:"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22" />
                            <TextBlock x:Name="HotkeyShortcutValueText"
                                       Grid.Column="1"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22"
                                       Text="Toggle" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,0,0,8"
                            CornerRadius="22"
                            BorderThickness="1"
                            BorderBrush="#7A8698"
                            Padding="18,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Enter:"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22" />
                            <TextBlock Grid.Column="1"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22"
                                       Text="Open" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,0,0,8"
                            CornerRadius="22"
                            BorderThickness="1"
                            BorderBrush="#7A8698"
                            Padding="18,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Esc:"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22" />
                            <TextBlock Grid.Column="1"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="22"
                                       Text="Hide" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Margin="0,18,0,8"
                               Style="{StaticResource SubHeaderStyle}"
                               Text="Optional toggles" />

                    <Border Grid.Row="4"
                            Margin="0,0,0,8"
                            CornerRadius="24"
                            BorderThickness="1"
                            BorderBrush="#5E6B7D"
                            Background="#374251"
                            Padding="16,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show key hints in footer"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="21"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="KeyHintsToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource SwitchStyle}"
                                      Checked="Toggle_Changed"
                                      Unchecked="Toggle_Changed" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Margin="0,0,0,8"
                            CornerRadius="24"
                            BorderThickness="1"
                            BorderBrush="#5E6B7D"
                            Background="#374251"
                            Padding="16,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show index status in header"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="21"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="IndexHeaderToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource SwitchStyle}"
                                      Checked="Toggle_Changed"
                                      Unchecked="Toggle_Changed" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="6"
                            CornerRadius="24"
                            BorderThickness="1"
                            BorderBrush="#5E6B7D"
                            Background="#374251"
                            Padding="16,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show filter chips"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="21"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="FilterChipsToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource SwitchStyle}"
                                      Checked="Toggle_Changed"
                                      Unchecked="Toggle_Changed" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
