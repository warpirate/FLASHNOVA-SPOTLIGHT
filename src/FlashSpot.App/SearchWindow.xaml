<Window x:Class="FlashSpot.App.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlashSpot"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8ECEF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#A8B2BD" />
        <SolidColorBrush x:Key="TextMuted" Color="#7E8792" />
        <SolidColorBrush x:Key="ShellStroke" Color="#3E4651" />
        <SolidColorBrush x:Key="CardStroke" Color="#3C4450" />
        <SolidColorBrush x:Key="SearchStroke" Color="#4A5462" />
        <SolidColorBrush x:Key="RowStroke" Color="#3A434F" />
        <SolidColorBrush x:Key="RowHoverStroke" Color="#566274" />
        <SolidColorBrush x:Key="RowSelectedStroke" Color="#6E7F95" />
        <SolidColorBrush x:Key="ChipStroke" Color="#4C5562" />

        <LinearGradientBrush x:Key="ShellBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#252A31" Offset="0" />
            <GradientStop Color="#1D2229" Offset="0.6" />
            <GradientStop Color="#181C22" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2C333C" Offset="0" />
            <GradientStop Color="#242A32" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2A3038" Offset="0" />
            <GradientStop Color="#252C33" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="#333B46" />
            <Setter Property="BorderBrush" Value="#4D5766" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3C4653" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#627082" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B323C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuitButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Background" Value="#4A3C44" />
            <Setter Property="BorderBrush" Value="#665462" />
        </Style>

        <Style x:Key="ResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Padding" Value="12,8,12,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="{StaticResource RowBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource RowStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#323B46" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource RowHoverStroke}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A4654" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource RowSelectedStroke}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Width="1180" Margin="0,30,0,0">
        <Border CornerRadius="30" Background="#0E1116" Opacity="0.5" />

        <Border CornerRadius="30"
                BorderThickness="1"
                BorderBrush="{StaticResource ShellStroke}"
                Background="{StaticResource ShellBackground}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="2" Color="#000000" Opacity="0.45" />
            </Border.Effect>

            <Grid Margin="16,14,16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FlashSpot"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="48"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="IndexHeaderText"
                                   Margin="0,-2,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="13"
                                   Text="Ready | Indexed 0 items" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Margin="8,4,0,0"
                            Style="{StaticResource HeaderButtonStyle}"
                            Content="Tools"
                            Click="ToolsButton_Click" />
                    <Button Grid.Column="2"
                            Margin="8,4,0,0"
                            Style="{StaticResource QuitButtonStyle}"
                            Content="Quit"
                            Click="QuitButton_Click" />
                </Grid>

                <Border Grid.Row="1"
                        Padding="13,9,13,9"
                        CornerRadius="16"
                        BorderThickness="1"
                        BorderBrush="{StaticResource SearchStroke}"
                        Background="#2B323B">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="?"
                                   FontSize="16"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,9,0" />

                        <TextBox x:Name="SearchInput"
                                 Grid.Column="1"
                                 Style="{StaticResource SearchBoxStyle}"
                                 TextChanged="SearchInput_TextChanged" />

                        <TextBlock x:Name="HotkeyHintText"
                                   Grid.Column="2"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Text="Alt+Space" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              Margin="0,8,0,6"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#2F3640" BorderBrush="{StaticResource ChipStroke}" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,6,0"><TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="Bahnschrift SemiBold" FontSize="11" Text="Apps" /></Border>
                        <Border Background="#2F3640" BorderBrush="{StaticResource ChipStroke}" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,6,0"><TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="Bahnschrift SemiBold" FontSize="11" Text="Folders" /></Border>
                        <Border Background="#2F3640" BorderBrush="{StaticResource ChipStroke}" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,6,0"><TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="Bahnschrift SemiBold" FontSize="11" Text="Documents" /></Border>
                        <Border Background="#2F3640" BorderBrush="{StaticResource ChipStroke}" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,6,0"><TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="Bahnschrift SemiBold" FontSize="11" Text="Images" /></Border>
                        <Border Background="#2F3640" BorderBrush="{StaticResource ChipStroke}" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,6,0"><TextBlock Foreground="{StaticResource TextSecondary}" FontFamily="Bahnschrift SemiBold" FontSize="11" Text="Recent" /></Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Margin="0,0,0,7">
                    <ProgressBar x:Name="IndexingProgressBar"
                                 Height="4"
                                 Margin="0,0,0,5"
                                 IsIndeterminate="True"
                                 Foreground="#7A8491"
                                 Background="#313840"
                                 Visibility="Collapsed" />
                    <TextBlock x:Name="SearchStatusText"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="14"
                               Text="Type to search your existing FlashSpot index." />
                </StackPanel>

                <Border Grid.Row="4"
                        Background="{StaticResource PanelBackground}"
                        BorderBrush="{StaticResource CardStroke}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="8">
                    <ListBox x:Name="ResultsList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="2,0,2,0"
                             MinHeight="320"
                             MaxHeight="450"
                             ItemContainerStyle="{StaticResource ResultItemStyle}"
                             SelectionMode="Single"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ResultsList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="40"
                                            Height="28"
                                            CornerRadius="8"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Background="#3A424D"
                                            BorderBrush="#566172"
                                            BorderThickness="1">
                                        <Grid>
                                            <Image Width="16"
                                                   Height="16"
                                                   Source="{Binding IconImage}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding IconText}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontFamily="Bahnschrift SemiBold"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Bahnschrift SemiBold"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Cascadia Mono"
                                                   FontSize="11"
                                                   Margin="0,0,0,1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateText}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Cascadia Mono"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding SizeText}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Bahnschrift SemiBold"
                                                   FontSize="15"
                                                   HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Grid Grid.Row="5" Margin="2,8,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="QueueFooterText"
                               Grid.Column="0"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="13"
                               Text="Pending 0 | Failed 0" />

                    <TextBlock x:Name="KeyHintFooterText"
                               Grid.Column="1"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="13"
                               Text="Enter: Open   Esc: Hide   Alt+Space: Toggle" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

