<Window x:Class="FlashSpot.App.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlashSpot"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid x:Name="OverlayRoot" MouseDown="Overlay_MouseDown">
        <!-- Dim overlay -->
        <Border Background="{StaticResource OverlayDimBrush}" />

        <!-- Spotlight card — positioned at upper-third like macOS -->
        <Border x:Name="SpotlightCard"
                Width="680"
                VerticalAlignment="Top"
                Margin="0,180,0,0"
                HorizontalAlignment="Center"
                CornerRadius="{StaticResource CardCornerRadius}"
                Background="{StaticResource CardFillBrush}"
                BorderBrush="{StaticResource CardStrokeBrush}"
                BorderThickness="1"
                MouseDown="Card_MouseDown"
                RenderTransformOrigin="0.5,0">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" ShadowDepth="12" Direction="270"
                                  Color="#000000" Opacity="0.55" />
            </Border.Effect>

            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Search bar -->
                    <RowDefinition Height="Auto" />  <!-- Separator -->
                    <RowDefinition Height="Auto" />  <!-- Filter pills -->
                    <RowDefinition Height="Auto" />  <!-- Status -->
                    <RowDefinition Height="Auto" />  <!-- Results -->
                    <RowDefinition Height="Auto" />  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ════ Search Bar (Hero element) ════ -->
                <Border Grid.Row="0"
                        Padding="14,10"
                        CornerRadius="{StaticResource SearchBarCornerRadius}"
                        Background="{StaticResource SearchFillBrush}"
                        BorderBrush="{StaticResource SearchStrokeBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Search icon -->
                        <TextBlock Grid.Column="0"
                                   Margin="2,0,10,0"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Text="&#xE721;" />

                        <!-- Search input + placeholder -->
                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchInput"
                                     Style="{StaticResource SearchTextBoxStyle}"
                                     TextChanged="SearchInput_TextChanged" />

                            <TextBlock x:Name="SearchPlaceholderText"
                                       Margin="2,0,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Text="Search">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Hotkey badge -->
                        <Border Grid.Column="2"
                                Margin="8,0,4,0"
                                Padding="8,3"
                                CornerRadius="6"
                                Background="#12FFFFFF"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="HotkeyHintText"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Text="Alt+Space" />
                        </Border>

                        <!-- Settings button (minimal) -->
                        <Button Grid.Column="3"
                                Margin="2,0,0,0"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Settings"
                                Click="OpenSettingsButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE713;" />
                        </Button>
                    </Grid>
                </Border>

                <!-- ════ Separator ════ -->
                <Border Grid.Row="1"
                        Height="1"
                        Margin="12,0"
                        Background="{StaticResource SeparatorBrush}" />

                <!-- ════ Filter pills (compact) ════ -->
                <ScrollViewer x:Name="FilterChipsScrollViewer"
                              Grid.Row="2"
                              Margin="4,8,4,0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="All"
                                     Tag="All"
                                     GroupName="SearchFilter"
                                     IsChecked="True"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                        <RadioButton Content="Files"
                                     Tag="Files"
                                     GroupName="SearchFilter"
                                     Margin="6,0,0,0"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                        <RadioButton Content="Apps"
                                     Tag="Apps"
                                     GroupName="SearchFilter"
                                     Margin="6,0,0,0"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                        <RadioButton Content="Web"
                                     Tag="Web"
                                     GroupName="SearchFilter"
                                     Margin="6,0,0,0"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                        <RadioButton Content="Images"
                                     Tag="Images"
                                     GroupName="SearchFilter"
                                     Margin="6,0,0,0"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                        <RadioButton Content="System"
                                     Tag="System"
                                     GroupName="SearchFilter"
                                     Margin="6,0,0,0"
                                     Style="{StaticResource PillRadioStyle}"
                                     Checked="FilterPill_Checked" />
                    </StackPanel>
                </ScrollViewer>

                <!-- ════ Status row ════ -->
                <StackPanel Grid.Row="3" Margin="8,8,8,0">
                    <ProgressBar x:Name="IndexingProgressBar"
                                 Height="2"
                                 IsIndeterminate="True"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="#10FFFFFF"
                                 Visibility="Collapsed" />
                    <TextBlock x:Name="SearchStatusText"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="13"
                               Text="Type to search" />
                    <!-- Optional index header (hidden by default) -->
                    <TextBlock x:Name="IndexHeaderText"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="12"
                               Visibility="Collapsed"
                               Text="Ready | Indexed 0 items" />
                </StackPanel>

                <!-- ════ Results ════ -->
                <ListBox x:Name="ResultsList"
                         Grid.Row="4"
                         Margin="0,6,0,0"
                         Style="{StaticResource ResultsListBoxStyle}"
                         ItemContainerStyle="{StaticResource ResultItemStyle}"
                         MaxHeight="440"
                         MouseDoubleClick="ResultsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="{StaticResource IconTileCornerRadius}"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource IconTileFillBrush}"
                                        BorderBrush="{StaticResource IconTileStrokeBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Image Width="20" Height="20"
                                               Source="{Binding IconImage}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding IconText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Title + Subtitle -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="12"
                                               Margin="0,1,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Meta (type badge) -->
                                <Border Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Padding="8,3"
                                        CornerRadius="6"
                                        Background="#0CFFFFFF"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SizeText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"
                                               FontSize="11"
                                               FontWeight="Medium" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ════ Footer ════ -->
                <Grid Grid.Row="5" Margin="8,6,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="QueueFooterText"
                               Grid.Column="0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"
                               Text="Pending 0 | Failed 0" />

                    <TextBlock x:Name="KeyHintFooterText"
                               Grid.Column="1"
                               Foreground="#50FFFFFF"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Text="↵ Open  ⌃↵ Reveal  ⎋ Close" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
